# ════════════════════════════════════════════════════════════════
#  Скопируй в .env и заполни. НЕ коммить .env в git.
#  На сервере этот файл создаёт install.sh интерактивно.
# ════════════════════════════════════════════════════════════════

PUBLIC_URL=https://mess.happypartner.ru

# ── Битрикс24 ─────────────────────────────────────────────────
B24_DOMAIN=happypartner.bitrix24.ru
B24_CLIENT_ID=local.6a493eed0dcf88.66891638
B24_CLIENT_SECRET=
B24_LINE_ID=2
B24_CONNECTOR_ID=maxbridge
# Извлекается автоматически из первого входящего события Битрикса
B24_APPLICATION_TOKEN=

# ── Адаптеры (Docker-имена сервисов) ──────────────────────────
ADAPTERS=whatsapp=http://wa:9003,max=http://max:9002,telegram=http://telegram:9001

# ── Telegram ──────────────────────────────────────────────────
TG_ENABLED=true
TG_API_ID=
TG_API_HASH=
TG_SESSION_FILE=/sessions/telegram.session
# Xray SOCKS5 прокси (Docker-сервис)
TG_PROXY_HOST=xray
TG_PROXY_PORT=1080

# ── WhatsApp ──────────────────────────────────────────────────
WA_ENABLED=true
WA_SESSION_DIR=/sessions/wa

# ── MAX userbot ───────────────────────────────────────────────
MAX_ENABLED=true
MAX_SESSION_FILE=/sessions/max.session

# ── Telegram proxy (VLESS, хранить только в .env) ────────────
VLESS_URL=

# ── Веб-морда (генерируется install.sh) ───────────────────────
ADMIN_USER=admin
ADMIN_PASS_HASH=
