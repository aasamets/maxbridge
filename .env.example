# ════════════════════════════════════════════════════════════════
#  Скопируй в .env и заполни. НЕ коммить .env в git.
#  На сервере этот файл создаёт install.sh интерактивно.
# ════════════════════════════════════════════════════════════════

PUBLIC_URL=https://your-domain.example.com

# ── Битрикс24 ─────────────────────────────────────────────────
B24_DOMAIN=your-portal.bitrix24.ru
B24_CLIENT_ID=local.XXXXXXXXXXXXXXXX
B24_CLIENT_SECRET=
B24_LINE_ID=2
B24_CONNECTOR_ID=maxbridge
# Извлекается автоматически из первого входящего события Битрикса
B24_APPLICATION_TOKEN=

# ── Адаптеры (Docker-имена сервисов) ──────────────────────────
ADAPTERS=whatsapp=http://wa:9003,max=http://max:9002,telegram=http://telegram:9001

# ── Telegram ──────────────────────────────────────────────────
TG_ENABLED=true
TG_API_ID=
TG_API_HASH=
TG_SESSION_FILE=/sessions/telegram.session
# Xray SOCKS5 прокси (Docker-сервис)
TG_PROXY_HOST=xray
TG_PROXY_PORT=1080

# ── WhatsApp ──────────────────────────────────────────────────
WA_ENABLED=true
WA_SESSION_DIR=/sessions/wa
# Прокси для WA: оставить пустым — WA в РФ не заблокирован
WA_PROXY_HOST=
WA_PROXY_PORT=1080

# ── MAX (GREEN-API) ───────────────────────────────────────────
MAX_ENABLED=true
# Получить на green-api.com/max после подключения номера
GREENAPI_ID_INSTANCE=
GREENAPI_TOKEN=
# Публичный URL для вебхука GREEN-API (= PUBLIC_URL + /adapters/max/webhook)
GREENAPI_WEBHOOK_URL=

# ── Telegram proxy (VLESS, хранить только в .env) ─────────────
VLESS_URL=

# ── Веб-морда (генерируется install.sh) ───────────────────────
ADMIN_USER=admin
ADMIN_PASS=
